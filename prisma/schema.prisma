// Esquema de Caja: cuentas, movimientos, arqueos, tasas y deudas.
// Los campos "kind"/"status"/"direction" son strings validados con las
// constantes de src/lib/domain.ts + Zod (herencia de SQLite; se mantiene).
// Montos SIEMPRE en unidades menores (enteros); tasas escaladas ×10 000.

generator client {
  provider = "prisma-client-js"
}

// Neon Postgres: DATABASE_URL es el endpoint con pooler (runtime);
// DIRECT_URL el directo (migraciones).
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Currency {
  id            String  @id @default(cuid())
  userId        String
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  code          String
  name          String
  symbol        String
  decimalPlaces Int     @default(2)
  isBase        Boolean @default(false)
  active        Boolean @default(true)

  denominations       Denomination[]
  accounts            Account[]
  transactions        Transaction[]
  counterTransactions Transaction[]  @relation("CounterCurrencyTx")
  ratesFrom           ExchangeRate[] @relation("RateFrom")
  ratesTo             ExchangeRate[] @relation("RateTo")
  debts               Debt[]
  paymentPlans        PaymentPlan[]

  @@unique([userId, code])
}

model Denomination {
  id         String   @id @default(cuid())
  currencyId String
  currency   Currency @relation(fields: [currencyId], references: [id])
  valueMinor Int
  kind       String // BILL | COIN
  active     Boolean  @default(true)

  countLines CashCountLine[]
  txLines    TransactionDenomination[]

  @@unique([currencyId, valueMinor, kind])
}

// Agrupación libre de cuentas (Negocio, Personal, etc.). Borrar un grupo
// deja sus cuentas "Sin grupo" (onDelete: SetNull).
model AccountGroup {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())

  accounts Account[]

  @@unique([userId, name])
}

model Account {
  id         String        @id @default(cuid())
  userId     String
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  type       String // CASH | BANK | DIGITAL
  currencyId String
  currency   Currency      @relation(fields: [currencyId], references: [id])
  groupId    String?
  group      AccountGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  icon       String?
  archived   Boolean       @default(false)
  createdAt  DateTime      @default(now())

  transactions        Transaction[]             @relation("AccountTx")
  counterTransactions Transaction[]             @relation("CounterAccountTx")
  cashCounts          CashCount[]
  debts               Debt[]
  paymentPlans        PaymentPlan[]
  txDenominations     TransactionDenomination[]

  @@index([userId])
}

model Category {
  id     String  @id @default(cuid())
  userId String
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name   String
  kind   String // EXPENSE | INCOME
  icon   String?
  active Boolean @default(true)

  transactions Transaction[]

  @@unique([userId, name, kind])
}

// Libro mayor. amountMinor es positivo salvo en ADJUSTMENT (con signo).
// TRANSFER: accountId = origen, counterAccountId = destino;
// counterAmountMinor va en la moneda del destino (rateScaled si cruza monedas).
model Transaction {
  id                 String    @id @default(cuid())
  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind               String // INCOME | EXPENSE | TRANSFER | ADJUSTMENT
  accountId          String
  account            Account   @relation("AccountTx", fields: [accountId], references: [id])
  counterAccountId   String?
  counterAccount     Account?  @relation("CounterAccountTx", fields: [counterAccountId], references: [id])
  amountMinor        Int
  currencyId         String
  currency           Currency  @relation(fields: [currencyId], references: [id])
  counterAmountMinor Int?
  // Moneda de counterAmountMinor: en TRANSFER, la de la cuenta destino; en
  // INCOME/EXPENSE multi-moneda, la moneda original en que se hizo la operación.
  counterCurrencyId  String?
  counterCurrency    Currency? @relation("CounterCurrencyTx", fields: [counterCurrencyId], references: [id])
  rateScaled         Int?
  categoryId         String?
  category           Category? @relation(fields: [categoryId], references: [id])
  note               String?
  occurredAt         DateTime  @default(now())
  createdAt          DateTime  @default(now())

  cashCount         CashCount?
  installment       Installment?
  debtPayment       DebtPayment?
  denominationLines TransactionDenomination[]

  @@index([accountId, occurredAt])
  @@index([occurredAt])
  @@index([userId, occurredAt])
}

// Desglose de denominaciones de un movimiento en una caja CASH_BOX.
// accountId identifica el LADO del movimiento (en TRANSFER puede haber
// desglose de origen y de destino); el signo se deriva del kind:
// entra (+) INCOME y destino de TRANSFER; sale (−) EXPENSE y origen.
// La disponibilidad de la caja = último arqueo ± estos desgloses.
model TransactionDenomination {
  id             String       @id @default(cuid())
  transactionId  String
  transaction    Transaction  @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  accountId      String
  account        Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  denominationId String
  denomination   Denomination @relation(fields: [denominationId], references: [id])
  quantity       Int

  @@unique([transactionId, accountId, denominationId])
  @@index([accountId])
}

// Tasa manual entre un PAR de monedas: unidades de `toCurrency` por 1 unidad
// de `fromCurrency`, ×10 000. Histórico puro: nunca se sobreescribe, la
// vigente por par es la de mayor effectiveAt. Si falta el par directo, la
// app usa el inverso (o compone vía la moneda base).
model ExchangeRate {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromCurrencyId String
  fromCurrency   Currency @relation("RateFrom", fields: [fromCurrencyId], references: [id])
  toCurrencyId   String
  toCurrency     Currency @relation("RateTo", fields: [toCurrencyId], references: [id])
  rateScaled     Int
  source         String   @default("MANUAL")
  effectiveAt    DateTime @default(now())
  createdAt      DateTime @default(now())

  @@index([fromCurrencyId, toCurrencyId, effectiveAt])
  @@index([userId, effectiveAt])
}

model CashCount {
  id              String       @id @default(cuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId       String
  account         Account      @relation(fields: [accountId], references: [id])
  countedAt       DateTime     @default(now())
  totalMinor      Int
  expectedMinor   Int
  differenceMinor Int
  note            String?
  adjustmentTxId  String?      @unique
  adjustmentTx    Transaction? @relation(fields: [adjustmentTxId], references: [id])

  lines CashCountLine[]

  @@index([userId])
}

model CashCountLine {
  id             String       @id @default(cuid())
  cashCountId    String
  cashCount      CashCount    @relation(fields: [cashCountId], references: [id], onDelete: Cascade)
  denominationId String
  denomination   Denomination @relation(fields: [denominationId], references: [id])
  quantity       Int

  @@unique([cashCountId, denominationId])
}

model Contact {
  id     String  @id @default(cuid())
  userId String
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name   String
  phone  String?
  note   String?

  debts Debt[]
  plans PaymentPlan[]

  @@index([userId])
}

model Debt {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contactId   String
  contact     Contact  @relation(fields: [contactId], references: [id])
  direction   String // RECEIVABLE | PAYABLE
  description String
  totalMinor  Int
  currencyId  String
  currency    Currency @relation(fields: [currencyId], references: [id])
  // Cuenta preferida para los abonos (misma moneda); editable tras crear.
  accountId   String?
  account     Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  status      String   @default("OPEN") // OPEN | PAID | CANCELLED
  createdAt   DateTime @default(now())

  plans    PaymentPlan[]
  payments DebtPayment[]

  @@index([userId])
}

// Plan de cuotas: ligado a una deuda o standalone (mensualidad tipo renta).
model PaymentPlan {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  debtId      String?
  debt        Debt?     @relation(fields: [debtId], references: [id])
  contactId   String?
  contact     Contact?  @relation(fields: [contactId], references: [id])
  kind        String // COLLECT | PAY
  description String
  currencyId  String
  currency    Currency  @relation(fields: [currencyId], references: [id])
  // Cuenta preferida para pagar/cobrar las cuotas (misma moneda); editable.
  accountId   String?
  account     Account?  @relation(fields: [accountId], references: [id], onDelete: SetNull)
  amountMinor Int
  frequency   String // ONCE | WEEKLY | BIWEEKLY | MONTHLY
  dayOfMonth  Int?
  nextDueAt   DateTime
  endAt       DateTime?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  installments Installment[]

  @@index([userId])
}

// Cuota materializada. VENCIDA es derivado: PENDING con dueAt < ahora.
model Installment {
  id            String       @id @default(cuid())
  planId        String
  plan          PaymentPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)
  dueAt         DateTime
  amountMinor   Int
  status        String       @default("PENDING") // PENDING | PAID | SKIPPED
  transactionId String?      @unique
  transaction   Transaction? @relation(fields: [transactionId], references: [id])
  settledAt     DateTime?

  @@unique([planId, dueAt])
}

model DebtPayment {
  id            String      @id @default(cuid())
  debtId        String
  debt          Debt        @relation(fields: [debtId], references: [id])
  transactionId String      @unique
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  amountMinor   Int
  paidAt        DateTime    @default(now())
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  sessions      Session[]
  currencies    Currency[]
  accountGroups AccountGroup[]
  accounts      Account[]
  categories    Category[]
  transactions  Transaction[]
  exchangeRates ExchangeRate[]
  cashCounts    CashCount[]
  contacts      Contact[]
  debts         Debt[]
  paymentPlans  PaymentPlan[]
}

// Sesión con token opaco: la cookie lleva el token en claro y en BD se
// guarda su hash SHA-256. Expiración fija de 30 días, sin renovación.
model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}
