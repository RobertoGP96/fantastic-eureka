# Neon Postgres — cadena POOLED para el runtime.
# Obligatorio: &schema=caja&pgbouncer=true (PgBouncer) + límites de conexión.
DATABASE_URL='postgresql://USUARIO:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require&schema=caja&pgbouncer=true&connect_timeout=15&connection_limit=10'

# Cadena DIRECTA (sin -pooler) para migraciones de Prisma.
DIRECT_URL='postgresql://USUARIO:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require&schema=caja'

# "false" bloquea el registro de usuarios nuevos (recomendado en producción:
# los usuarios comparten los datos de la instancia).
# ALLOW_REGISTRATION="false"

# Nombre de la app (opcional)
# NEXT_PUBLIC_APP_NAME="Caja"
